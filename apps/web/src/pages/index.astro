---
import Layout from '../layouts/Layout.astro';
import BlockRenderer from '../components/BlockRenderer.astro';
import { api } from '../lib/api';

const page = await api.get('/pages/home') as any;

// If no home page is created, show a welcome message
const showWelcome = !page;
---

<Layout title={page?.title || "Welcome to our site"}>
	{showWelcome ? (
		<div class="flex flex-col items-center justify-center min-h-[60vh] text-center p-8">
			<h1 class="text-4xl font-bold mb-4">Site Setup Complete</h1>
			<p class="text-gray-600 mb-8 max-w-md">Head over to the dashboard and create a page with the slug "home" to see your content here.</p>
			<a href="http://localhost:5173" class="px-6 py-3 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700">Go to Dashboard</a>
		</div>
	) : (
		<BlockRenderer blocks={page.blocks} />
	)}
</Layout>