{
  "name": "@kz/server",
  "type": "module",
  "scripts": {
    "build": "npm run cf-typegen && npm run build:css && npm run typecheck",
    "build:css": "tailwindcss -i ./src/styles/global.css -o ./public/style.css --minify",
    "typecheck": "tsc --noEmit",
    "lint": "echo Linting server...",
    "dev": "wrangler dev",
    "dev:css": "tailwindcss -i ./src/styles/global.css -o ./public/style.css --watch",
    "deploy": "npm run build && wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:create": "bunx wrangler d1 create app-db",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bunx wrangler d1 migrations apply app-db --local",
    "db:migrate:remote": "bunx wrangler d1 migrations apply app-db --remote",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@kz/shared": "workspace:*",
    "@tailwindcss/cli": "^4.2.1",
    "better-auth": "latest",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.3",
    "nanoid": "^5.1.6",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "@types/nanoid": "^3.0.0",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.7.3",
    "wrangler": "^4.4.0"
  }
}
